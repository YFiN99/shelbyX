# Private key akun Shelby untuk server (dari: shelby account list)
SHELBY_ACCOUNT_PRIVATE_KEY=ed25519-priv-0x...

# API key dari geomi.dev (server key)
SHELBY_API_KEY=aptoslabs_...

# Shelby blob base URL
SHELBY_BASE_URL=https://api.testnet.shelby.xyz/shelby/v1/blobs

# Frontend env (prefix VITE_)
VITE_SHELBY_BASE_URL=https://api.testnet.shelby.xyz/shelby/v1/blobs
